# Base URL of the cloud control plane (no trailing slash).
PISIGNAGE_SERVER=http://localhost:4000

# Where to persist the device token + id. Defaults to ./.state in dev,
# /etc/pisignage on the Pi (set by the installer).
# PISIGNAGE_STATE_DIR=/etc/pisignage

# Display backend: "auto" (detect), "chromium" (Pi kiosk), or "console" (dev/log).
PISIGNAGE_DISPLAY=auto

# Kiosk launch command template. {url} is substituted.
# Validated on Pi 5 / Raspberry Pi OS (Trixie) / labwc Wayland session.
# Note: the binary is `chromium` (not `chromium-browser`), and --password-store=basic
# is required to avoid the GNOME-keyring "create password" dialog blocking the screen.
PISIGNAGE_KIOSK_CMD=chromium --kiosk --ozone-platform=wayland --no-first-run --noerrdialogs --disable-infobars --disable-session-crashed-bubble --password-store=basic {url}
