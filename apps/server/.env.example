# --- Database (Turso / libSQL) ---
# Local dev: a SQLite file (no auth token needed).
DATABASE_URL=file:./local.db
# Production (Turso cloud): uncomment and fill these instead.
# DATABASE_URL=libsql://your-db-name.turso.io
# DATABASE_AUTH_TOKEN=your-turso-auth-token

# Secret used to sign dashboard admin JWTs. Generate a long random string for prod.
JWT_SECRET=dev-only-change-me-to-a-long-random-string

# Bootstrap admin (created/updated on `npm run db:seed`)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# Default org created on seed
ORG_NAME=My Business

# HTTP port
PORT=4000

# Public base URL of this server (used in docs / agent config). No trailing slash.
PUBLIC_BASE_URL=http://localhost:4000

# Comma-separated allowed dashboard origins for CORS
CORS_ORIGINS=http://localhost:5173
